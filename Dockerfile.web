# syntax=docker/dockerfile:1.7

ARG BUNNYLAND_WEB_IMAGE=ghcr.io/thalismind/bunnyland-web:main

FROM node:22-bookworm-slim AS build

WORKDIR /app/web

COPY --from=bunnyland-ui-web / /bunnyland-ui-web
COPY web/package.json web/package-lock.json ./
RUN npm ci

COPY web/admin.html web/vite.config.ts web/tsconfig.json ./
COPY web/src ./src

ENV BUNNYLAND_RL_BASE=/rl/
RUN npm run build

FROM build AS test

COPY web/test ./test
RUN mkdir -p /reports
CMD ["node", "--test", "--test-reporter=junit", "--test-reporter-destination=/reports/web.xml"]

FROM ${BUNNYLAND_WEB_IMAGE}

COPY --from=build /app/web/dist /usr/share/nginx/html/rl
